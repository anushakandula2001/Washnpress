{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "appName": {
      "value": "washnpress-platform-app"
    },
    "appServicePlanName": {
      "value": "washnpress-platform-plan"
    },
    "acrServer": {
      "value": "yourregistry.azurecr.io"
